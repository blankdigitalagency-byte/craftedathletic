{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "Static Site (live-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", ".", "--port=3001", "--no-browser"],
      "port": 3001
    },
    {
      "name": "Static Site (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    }
  ]
}
